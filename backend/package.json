{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Portfolio backend API with Node.js, Express, and MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node scripts/setup-db.js",
    "build:frontend": "cd ../frontend && npm run build"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
